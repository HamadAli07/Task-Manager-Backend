# Copy to .env and fill in values (never commit .env)

# MongoDB Atlas: Cluster → Connect → Drivers → copy SRV connection string
# Use your DB user + password; URL-encode special characters in the password (@ # % etc.)
# Database name in the path must match Atlas (e.g. /task-manager)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.2sjjvgw.mongodb.net/task-manager?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-a-long-random-string

PORT=3000
